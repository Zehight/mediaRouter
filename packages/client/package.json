{
  "name": "@miragari/client",
  "version": "0.1.1",
  "description": "Client SDK for routing media generation requests across provider plugins.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "license": "MIT",
  "author": "Zehight",
  "homepage": "https://github.com/Zehight/mediaRouter#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Zehight/mediaRouter.git",
    "directory": "packages/client"
  },
  "bugs": {
    "url": "https://github.com/Zehight/mediaRouter/issues"
  },
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "media-router",
    "sdk",
    "ai",
    "image-generation",
    "video-generation"
  ],
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "prepack": "pnpm --dir ../core run build && pnpm run build",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "typecheck:test": "tsc -p tsconfig.test.json",
    "test": "vitest run"
  },
  "dependencies": {
    "@miragari/core": "workspace:*"
  }
}
