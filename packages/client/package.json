{
  "name": "@miragari/ai-media-router-client",
  "version": "0.2.1",
  "description": "Client runtime for AI Media Router and multi-provider media generation workflows.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "license": "MIT",
  "author": "Zehight",
  "homepage": "https://github.com/Zehight/ai-media-router#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Zehight/ai-media-router.git",
    "directory": "packages/client"
  },
  "bugs": {
    "url": "https://github.com/Zehight/ai-media-router/issues"
  },
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "ai-media-router",
    "media-router",
    "sdk",
    "ai",
    "multimodal",
    "multi-provider",
    "image-generation",
    "video-generation"
  ],
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "prepack": "pnpm --dir ../core run build && pnpm run build",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "typecheck:test": "tsc -p tsconfig.test.json",
    "test": "vitest run"
  },
  "dependencies": {
    "@miragari/ai-media-router-core": "workspace:*"
  }
}
