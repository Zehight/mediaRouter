{
  "name": "media-router",
  "version": "0.1.0",
  "private": true,
  "description": "TypeScript-first SDK for routing image and video generation across media providers.",
  "homepage": "https://zehight.github.io/mediaRouter/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Zehight/mediaRouter.git"
  },
  "bugs": {
    "url": "https://github.com/Zehight/mediaRouter/issues"
  },
  "type": "module",
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "build": "pnpm -r build",
    "changeset": "changeset",
    "docs:serve": "python -m http.server 4173 -d site",
    "release:publish": "pnpm --filter @miragari/core publish --access public --no-git-checks && pnpm --filter @miragari/client publish --access public --no-git-checks && pnpm --filter @miragari/providers publish --access public --no-git-checks",
    "version-packages": "changeset version && pnpm install --no-frozen-lockfile",
    "typecheck": "pnpm -r typecheck",
    "typecheck:tests": "pnpm -r --if-present typecheck:test",
    "test": "pnpm -r test"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
